APP_NAME=med-doc-backend
APP_ENV=dev
API_PREFIX=/api
MONGO_URI=mongodb://localhost:27017
MONGO_DB=med_docs
MONGO_SERVER_SELECTION_TIMEOUT_MS=1500
MONGO_CONNECT_TIMEOUT_MS=1500
MONGO_SOCKET_TIMEOUT_MS=2000
OPENFDA_BASE_URL=https://api.fda.gov
OPENFDA_TIMEOUT_SECONDS=4.0
INTERACTION_CACHE_TTL_HOURS=24
EXTERNAL_API_TIMEOUT_SECONDS=4.0
